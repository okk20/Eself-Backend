# ─── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Required) ────────────────────────────────────────
# PostgreSQL connection string. Must start with postgres:// or postgresql://
# Examples:
#   Local:    postgres://postgres:password@localhost:5432/eself
#   Render:   postgres://user:password@host:5432/eself
#   Railway:  postgres://user:password@host:5432/eself
DATABASE_URL=postgres://postgres:password@localhost:5432/eself

# ─── Paystack ───────────────────────────────────────────────────
# Get these from https://dashboard.paystack.com/#/settings/developer
# Use sk_test_... for testing, sk_live_... for production
PAYSTACK_SECRET_KEY=YOUR_KEY_HERE
PAYSTACK_PUBLIC_KEY=YOUR_KEY_HERE

# ─── Authentication ─────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=YOUR_KEY_HERE

# ─── CORS (Optional) ────────────────────────────────────────────
# In production, set to your app's domain:
# CORS_ORIGINS=https://your-app.com,https://admin.your-app.com

# ─── Gemini AI (Required) ───────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_KEY_HERE

# ─── Rate Limiting (Optional) ───────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# ─── Paystack Timeout & Retry (Optional) ────────────────────────
# PAYSTACK_TIMEOUT_MS=15000
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY_MS=1000
