# PAYSTACK_BACKEND_URL: Base URL of your deployed Node.js backend for secure payments and AI features.
# Replace this with your actual deployed backend URL (must start with http:// or https://).
# NEVER put your Paystack Secret Key (sk_...) here — that belongs in server/.env only.
PAYSTACK_BACKEND_URL=https://your-backend.com

# PAYSTACK_PUBLIC_KEY: Your Paystack Public Key (e.g., pk_test_... or pk_live_...).
# Only the public key belongs in the Android app. The secret key stays on your server.
PAYSTACK_PUBLIC_KEY=YOUR_KEY_HERE

